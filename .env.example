# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15550000000
TWILIO_WHATSAPP_NUMBER=+14155238886   # Twilio sandbox WhatsApp number

# SeatGeek
SEATGEEK_CLIENT_ID=your_seatgeek_client_id
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# Google Cloud
GCP_PROJECT_ID=your_gcp_project_id

# Local dev only — point to Firestore emulator
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Set to true to log alerts without sending SMS
# DRY_RUN=false

# Set to true to skip Twilio signature validation (local dev)
# SKIP_TWILIO_VALIDATION=false
